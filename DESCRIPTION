Package: huggingfaceR
Type: Package
Title: Access 'Hugging Face' Models and Datasets
Version: 2.1.0
Authors@R: c(
  person("Alex", "Farach", email = "alexfarach@gmail.com", role = c("aut", "cre", "cph")),
